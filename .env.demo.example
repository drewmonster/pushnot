ADMIN_PASSWORD="replace-with-demo-password"
SESSION_SECRET="replace-with-long-random-session-secret"

# Demo mobile / EAS.
MOBILE_API_URL="https://your-api.example.com"
EXPO_PUBLIC_API_URL="https://your-api.example.com"
