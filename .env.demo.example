# Demo API and worker, using managed services.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DBNAME?schema=public&sslmode=require"
REDIS_URL="rediss://default:PASSWORD@HOST:6379"
API_PORT="4000"
API_HOST="0.0.0.0"
PORT=""
ADMIN_ORIGIN="https://your-admin.example.com"
PUSH_PROVIDER="expo"
PUSH_MOCK_FAILURE_RATE="0"
EXPO_ACCESS_TOKEN=""
ADMIN_ACTOR_ID="demo-admin"
ADMIN_API_TOKEN="replace-with-random-api-token"
DEMO_TENANT_ID="demo-tenant"
DEMO_TENANT_PUBLIC_KEY="replace-with-demo-public-app-key"

# Demo admin.
ADMIN_API_URL="https://your-api.example.com"
NEXT_PUBLIC_API_URL="https://your-api.example.com"
